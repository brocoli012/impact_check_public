{
  "name": "kurly-impact-checker",
  "version": "1.0.0",
  "description": "기획서 기반 코드 영향도 분석 도구",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "start": "NODE_OPTIONS='--max-old-space-size=2048' node dist/index.js",
    "dev": "NODE_OPTIONS='--max-old-space-size=2048' ts-node src/index.ts",
    "test": "NODE_OPTIONS='--max-old-space-size=2048' jest --config jest.config.js",
    "test:watch": "NODE_OPTIONS='--max-old-space-size=2048' jest --watch",
    "test:coverage": "NODE_OPTIONS='--max-old-space-size=2048' jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "keywords": [
    "impact-analysis",
    "code-analysis",
    "kurly",
    "claude-code-skill"
  ],
  "author": "Kurly Dev Team",
  "license": "MIT",
  "dependencies": {
    "@swc/core": "^1.15.11",
    "@types/pdf-parse": "^1.1.5",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.5",
    "js-yaml": "^4.1.1",
    "pdf-parse": "^2.4.5",
    "simple-git": "^3.31.1"
  },
  "optionalDependencies": {
    "tree-sitter": "^0.21.1",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-kotlin": "^0.3.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
